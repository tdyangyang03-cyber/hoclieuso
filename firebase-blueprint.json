{
  "entities": {
    "AppState": {
      "title": "AppState",
      "description": "Entire application state containing lessons, workbookSubmissions, and discussions synced in real-time",
      "type": "object",
      "properties": {
        "lessons": { "type": "array", "description": "List of lessons" },
        "workbookSubmissions": { "type": "array", "description": "Workbook submissions" },
        "mindmapSubmissions": { "type": "array", "description": "Mindmap submissions" },
        "parentFeedback": { "type": "array", "description": "Feedback from parents" },
        "discussionThreads": { "type": "array", "description": "Discussions threads" },
        "students": { "type": "array", "description": "Student roster" },
        "teacherNotes": { "type": "array", "description": "Teacher notes" },
        "lessonPlans": { "type": "array", "description": "Lesson plans" },
        "scheduleEvents": { "type": "array", "description": "Schedule events" },
        "studySheets": { "type": "array", "description": "Study sheet templates" },
        "activeLessonId": { "type": "string", "description": "Active lesson ID" },
        "activeFolder": { "type": "string", "description": "Active folder path" },
        "activeMaterialId": { "type": "string", "description": "Active material ID" },
        "activeSubTab": { "type": "string", "description": "Active student sub-tab" }
      }
    }
  },
  "firestore": {
    "classes/khoahoc4_chung": {
      "schema": "AppState",
      "description": "Global application state doc"
    },
    "app/state": {
      "schema": "AppState",
      "description": "Legacy application state doc"
    }
  }
}
