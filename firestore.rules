rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Legacy state synchronization path
    match /app/state {
      allow read, write: if true;
    }

    // 3. Global Single Classroom "khoahoc4_chung" path
    match /classes/khoahoc4_chung {
      allow read, write: if true;
    }
  }
}
